+		UINT scan_rem = MsgLen - LENGTH_802_11;
+		UINT ie_len;
+
+		/* Scan IEs to find SSID IE - some clients place vendor IEs first */
+		while (scan_rem >= 2) {
+			if (ie_scan[0] == IE_SSID) {
+				ssid_ie = ie_scan;
+				break;
+			}
+			ie_len = ie_scan[1] + 2;
+			if (ie_len < 2 || ie_len > scan_rem)
+				break;
+			ie_scan += ie_len;
+			scan_rem -= ie_len;
+		}
+
+		if (!ssid_ie || ssid_ie[1] > MAX_LEN_OF_SSID || ssid_ie[1] > (scan_rem - 2)) {
+			MTWF_DBG(NULL, DBG_CAT_TEST, CATTEST_SANITY, DBG_LVL_INFO,
