diff --git a/iwinfo_mtk.c b/iwinfo_mtk.c
index bbc7f004c3..bf2d6ea46d 100644
--- a/iwinfo_mtk.c
+++ b/iwinfo_mtk.c
@@ -5,9 +5,13 @@
 
 #include "iwinfo_mtk_ccode.c"
 
+static int mtk_is_ifup(const char *ifname);
 static inline int mtk_ioctl(const char *ifname, int cmd, struct iwreq *wrq)
 {
 	strncpy(wrq->ifr_name, ifname, IFNAMSIZ);
+	/* Skip ioctls when interface is down to avoid kernel log noise */
+	if (cmd != SIOCGIFFLAGS && !mtk_is_ifup(ifname))
+		return -1;
 	return iwinfo_ioctl(cmd, wrq);
 }
 
