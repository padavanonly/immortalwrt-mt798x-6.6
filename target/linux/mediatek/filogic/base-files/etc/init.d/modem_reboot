#!/bin/sh /etc/rc.common
START=99
STOP=0

start() {
	echo "do nothing"
}

stop() {
	for modem_no in 0 1 2; do
		dev=$(uci -q get modem.modem${modem_no}.at_port)
		[ -n "$dev" ] || continue
		[ -e "$dev" ] || continue

		for i in $(seq 1 3); do
			resp=$(sms_tool -d "$dev" at "AT+CFUN=1,1" 2>&1)
			echo "$resp" | grep -qi "ok" && {
				echo "[$dev] AT+CFUN sent successfully (try #$i)"
				break
			}
			sleep 1
		done

		for i in $(seq 1 15); do
			if [ ! -e "$dev" ]; then
				echo "[$dev] Device disconnected after $i s"
				break
			fi
			sleep 1
		done
	done
}
